.env

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# FVM Version Cache
.fvm/

# Firebase credentials (sensitive — injected at CI time)
**/GoogleService-Info.plist
**/google-services.json
/android/app/src/dev/google-services.json
/android/app/src/prod/google-services.json

# Freezed / json_serializable / envied — código generado por build_runner
# (se regenera con `dart run build_runner build --delete-conflicting-outputs`)
**/*.freezed.dart
**/*.g.dart
/pubspec.lock

# Auto-generated Flutter plugin registrant (regenerated por `flutter pub get`)
**/GeneratedPluginRegistrant.java

# Local environment / secrets (fuente de envied)
.env.backup